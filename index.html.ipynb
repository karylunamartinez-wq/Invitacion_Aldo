<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Invitación One Piece</title>

<link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@700&family=Montserrat&family=Marcellus&display=swap" rel="stylesheet">

<style>
body{
    margin:0;
    font-family:'Montserrat',sans-serif;
    background:linear-gradient(#a9e4fb,#1b7eb2);
    display:flex;
    justify-content:center;
    align-items:center;
    height:100vh;
}

.container{
    background:#ead7ab;
    padding:20px;
    border-radius:20px;
    text-align:center;
    max-width:600px;
    box-shadow:0 10px 30px rgba(0,0,0,0.3);
}

h1{
    font-family:'Cinzel';
    color:#7a4b1f;
}

.card{
    background:white;
    padding:10px;
    border-radius:12px;
    margin-top:10px;
}

.boton img{
    width:120px;
    cursor:pointer;
    transition:.2s;
}
.boton img:hover{
    transform:scale(1.1);
}

.overlay{
    position:fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    display:none;
    justify-content:center;
    align-items:center;
    background:rgba(0,0,0,0.7);
}

.overlay img{
    max-width:90%;
    border-radius:20px;
}

.close{
    position:absolute;
    top:20px;
    right:20px;
    font-size:30px;
    color:white;
    cursor:pointer;
}
</style>
</head>

<body>

<div class="container">

<h1 id="titulo"></h1>
<p id="subtitulo"></p>
<p><strong>Anfitrión:</strong> <span id="host"></span></p>

<div class="card">
<p><strong>Fecha:</strong> <span id="fecha"></span></p>
<p><strong>Hora:</strong> <span id="hora"></span></p>
<p><strong>Lugar:</strong> <span id="lugar"></span></p>
<p><strong>Dirección:</strong> <span id="direccion"></span></p>
</div>

<p id="mensaje"></p>

<h3>Cuenta regresiva</h3>
<p id="countdown"></p>

<div class="boton">
<img src="boton.png" onclick="abrir()">
</div>

</div>

<div class="overlay" id="overlay">
<span class="close" onclick="cerrar()">×</span>
<img src="One_Piece 1.png">
</div>

<script>
const evento={
titulo:"Cumpleaños de Aldo",
subtitulo:"¡Zarpamos a celebrar!",
anfitrion:"RAK",
fecha:"22 de Abril 2026",
hora:"2:00 PM",
lugar:"Sushi Roll",
direccion:"Plaza Inn",
mensaje:"Deseamos poder contar con tu presencia para celebrar al Rey de los Testados",
fecha_iso:"2026-04-22T14:00:00"
};

// pintar datos
document.getElementById("titulo").textContent=evento.titulo;
document.getElementById("subtitulo").textContent=evento.subtitulo;
document.getElementById("host").textContent=evento.anfitrion;
document.getElementById("fecha").textContent=evento.fecha;
document.getElementById("hora").textContent=evento.hora;
document.getElementById("lugar").textContent=evento.lugar;
document.getElementById("direccion").textContent=evento.direccion;
document.getElementById("mensaje").textContent=evento.mensaje;

// contador
function update(){
let diff=new Date(evento.fecha_iso)-new Date();
if(diff<0) return;

let d=Math.floor(diff/1000/60/60/24);
let h=Math.floor(diff/1000/60/60)%24;
let m=Math.floor(diff/1000/60)%60;
let s=Math.floor(diff/1000)%60;

document.getElementById("countdown").textContent=
`${d}d ${h}h ${m}m ${s}s`;
}
setInterval(update,1000);

// overlay
function abrir(){
document.getElementById("overlay").style.display="flex";
}
function cerrar(){
document.getElementById("overlay").style.display="none";
}
</script>

</body>
</html>